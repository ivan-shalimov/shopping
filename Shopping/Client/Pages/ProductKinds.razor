@page "/product-kinds"

@using System.Net.Http.Json
@using Radzen
@using Radzen.Blazor
@using Shopping.Shared.Requests


@inject HttpClient HttpClient

<div class="row">
    @if (_pending)
    {
        <p>Loading ...</p>
    }
    else
    {
            <table class="table">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th class="action-block-col" scope="col"></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><RadzenTextBox @bind-Value=@_newItem.Name Class="w-100" /></td>
                    <td>
                        @if (_editedItem == null)
                        {
                            <div class="action-block">
                                <button class="btn btn-primary" type="button" @onclick="@(async () => await Add())">Add</button>
                            </div>
                        }
                    </td>
                </tr>
                @foreach (var item in _list)
                {
                    <tr>
                        @if (_editedItem?.Id == item.Id)
                        {
                            <td><RadzenTextBox @bind-Value=@_editedItem.Name Class="w-100" /></td>
                        }
                        else
                        {
                            <td>@item.Name</td>
                        }
                        
                        @if (_editedItem != null)
                        {
                            @if (_editedItem.Id == item.Id)
                            {
                                <td>
                                    <div class="action-block">
                                        <button class="btn btn-primary" type="button" @onclick="@(async () => await Save())">Save</button>
                                        <button class="btn btn-primary ms-2" type="button" @onclick="@(async () => Cancel())">Cancel</button>
                                    </div>
                                </td>
                            }
                            else
                            {
                                <td></td>
                            }
                        }
                        else
                        {
                            <td>
                                <div class="action-block">
                                    <button class="btn btn-primary" type="button" @onclick="@(async () => StartEdit(item))">Edit</button>
                                    @if (!item.HasProducts)
                                    {
                                        <button class="btn btn-primary" type="button" @onclick="@(async () =>await Delete(item))">Delete</button>
                                    }
                                </div>
                            </td>
                        }    
                    </tr>
                }
            </tbody>
            </table>
    }
</div>

@code{
    private bool _pending = true;
    private ProductKindModel[]? _list;

    private ProductKindModel _newItem = new ProductKindModel();
    private ProductKindModel _editedItem = null;

    protected override Task OnInitializedAsync()
    {
        return Reload();
    }

    private async Task Reload()
    {
        _pending = true;
        _list = await HttpClient.GetFromJsonAsync<ProductKindModel[]>("/api/products/kinds");
        _pending = false;
    }

    private async Task Add()
    {
        var request = new AddProductKind
        {
            Id = Guid.NewGuid(),
            Name = _newItem.Name,
        };

        await HttpClient.PostAsJsonAsync("/api/products/kinds", request);

        _newItem = new ProductKindModel();

        await Reload().ConfigureAwait(false);
    }

    private void StartEdit(ProductKindModel product)
    {
        _editedItem = product;
    }

    private void Cancel()
    {
        _editedItem = null;
    }

    private async Task Save()
    {
        await HttpClient.PutAsJsonAsync($"/api/products/kinds/{_editedItem.Id}", new UpdateProductKind{ Name = _editedItem.Name });
        _editedItem = null;
        await Reload().ConfigureAwait(false);
    }

    private async Task Delete(ProductKindModel productKind)
    {
        await HttpClient.DeleteAsync($"/api/products/kinds/{productKind.Id}");
        await Reload().ConfigureAwait(false);
    }

}