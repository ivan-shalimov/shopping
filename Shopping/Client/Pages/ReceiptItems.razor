@page "/receipts/{ReceiptId}"

@using System.Net.Http.Json
@using Radzen
@using Radzen.Blazor
@using Shopping.Shared.Models.Results
@using Shopping.Shared.Requests


@inject HttpClient HttpClient

<div class="row">
    @if (_list == null)
    {
        <p>Loading ...</p>
    }
    else
    {
        <table class="table ">
            <thead>
                <tr>
                    <th scope="col">Item</th>
                    <th scope="col">Price</th>
                    <th scope="col">Amount</th>
                    <th scope="col">Cost</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <div style="display:flex; flex-direction:column">
                            <RadzenAutoComplete Data=@_products FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            TextProperty="Name"
                                            @bind-Value=@_newItem.ProductName
                                            Style="width: 100%;"
                                            Change="@ProductNameChanged" />
                            <span hidden="@(!_newItem.IsProductRequired)"
                              style="font-size:small; color:red">
                                Product is required
                            </span>
                        </div>
                    </td>
                    <td>
                        <div style="display:flex; flex-direction:column">
                            <RadzenNumeric ShowUpDown="false" TValue="decimal" @bind-Value=@_newItem.Price Class="w-100" />
                            <span hidden="@(!_newItem.IsPriceInvalid)"
                              style="font-size:small; color:red">
                                Price is invalid.
                            </span>
                        </div>
                    </td>
                    <td>
                        <div style="display:flex; flex-direction:column">
                            <RadzenNumeric ShowUpDown="false" TValue="decimal" @bind-Value=@_newItem.Amount Class="w-100" />
                            <span hidden="@(!_newItem.IsAmountInvalid)"
                              style="font-size:small; color:red">
                                Amount is invalid.
                            </span>
                        </div>
                    </td>
                    <td>@_newItem.Cost</td>
                    @if (_editedItem != null)
                    {
                        <td></td>
                    }
                    else
                    {
                        <td><div class="action-block"><button class="btn btn-primary" type="button" @onclick="@(async () => await Add())">Add</button></div></td>
                    }
                </tr>
                @foreach (var item in _list)
                {
                    @if (_editedItem?.Id == item.Id)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>
                                <div style="display:flex; flex-direction:column">
                                    <RadzenNumeric ShowUpDown="false" TValue="decimal" @bind-Value=@_editedItem.Price Class="w-100" />
                                    <span hidden="@(!_editedItem.IsPriceInvalid)"
                              style="font-size:small; color:red">
                                        Price is invalid.
                                    </span>
                                </div>
                            </td>
                            <td>
                                <div style="display:flex; flex-direction:column">
                                    <RadzenNumeric ShowUpDown="false" TValue="decimal" @bind-Value=@_editedItem.Amount Class="w-100" />
                                    <span hidden="@(!_editedItem.IsAmountInvalid)"
                              style="font-size:small; color:red">
                                        Amount is invalid.
                                    </span>
                                </div>
                            </td>
                            <td>@_editedItem.Cost</td>
                            <td>
                                <div class="action-block">
                                    <button class="btn btn-primary" type="button" @onclick="@(async () => await Save())">Save</button>
                                    <button class="btn btn-primary ms-2" type="button" @onclick="@(async () => Cancel())">Cancel</button>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.Price</td>
                            <td>@item.Amount</td>
                            <td>@item.Cost</td>
                            @if (_editedItem != null)
                            {
                                <td></td>
                            }
                            else
                            {
                                <td>
                                    <div class="action-block">
                                        <button class="btn btn-primary" type="button" @onclick="@(() => StartEdit(item))">Edit</button>
                                        <button class="btn btn-primary ms-2" type="button" @onclick="@(async () => await Delete(item.Id))">Delete</button>
                                    </div>
                                </td>
                            }
                        </tr>
                    }

                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter]
    public string ReceiptId { get; set; }

    private ReceiptItemModel[]? _list;

    private IEnumerable<ProductModel> _products = Array.Empty<ProductModel>();
    private AddReceiptItemModel _newItem = new AddReceiptItemModel();
    private EditReceiptItemModel _editedItem = null;

    private string _errorMessage = string.Empty;

    protected override Task OnInitializedAsync()
    {
        return Reload();
    }

    void OnLoadData(LoadDataArgs args)
    {
        Console.WriteLine($"LoadData with filter: {args.Filter}");


        InvokeAsync(StateHasChanged);
    }

    private async Task Reload()
    {
        _list = null;
        _products = await HttpClient.GetFromJsonAsync<ProductModel[]>("/api/products");
        _list = await HttpClient.GetFromJsonAsync<ReceiptItemModel[]>($"/api/receipts/{ReceiptId}/items");
        if (_list == null)
        {
            return;
        }
    }

    private void ProductNameChanged(object value)
    {
        var product = _products.FirstOrDefault(p => p.Name == _newItem.ProductName);
        _newItem.ProductId = product?.Id;
    }

    private async Task Add()
    {
        _newItem.IsSubmitted = true;
        if (!_newItem.IsValid)
        {
            return;
        }

        var request = new AddReceiptItem
            {
                Id = Guid.NewGuid(),
                ProductId = _newItem.ProductId.Value,
                Price = _newItem.Price,
                Amount = _newItem.Amount,
            };

        await HttpClient.PostAsJsonAsync($"/api/receipts/{ReceiptId}/items", request);

        _newItem = new AddReceiptItemModel();

        await Reload().ConfigureAwait(false);
    }

    private void StartEdit(ReceiptItemModel item)
    {
        _editedItem = new EditReceiptItemModel
            {
                Id = item.Id,
                Amount = item.Amount,
                Price = item.Price,
            };
    }

    private void Cancel()
    {
        _editedItem = null;
    }

    private async Task Save()
    {
        _editedItem.IsSubmitted = true;
        if (!_editedItem.IsValid)
        {
            return;
        }

        var request = new UpdateReceiptItem
            {
                Id = _editedItem.Id,
                Amount = _editedItem.Amount,
                Price = _editedItem.Price,
            };
        await HttpClient.PutAsJsonAsync($"/api/receipts/{ReceiptId}/items/{_editedItem.Id}", request);
        _editedItem = null;
        await Reload().ConfigureAwait(false);
    }

    private async Task Delete(Guid id)
    {
        await HttpClient.DeleteAsync($"/api/receipts/{ReceiptId}/items/{id}");
        await Reload().ConfigureAwait(false);
    }
}