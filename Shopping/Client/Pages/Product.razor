@page "/products"

<div class="row">
    @if (_pending)
    {
        <p>Loading ...</p>
    }
    else
    {
        <div class="filter">
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">@Localizer["Type"]</th>
                    <th scope="col">@Localizer["Name"]</th>
                    <th scope="col">
                        <span>@Localizer["Kind"]</span>
                        <RadzenDropDown @bind-Value=@_filterProductKindId TValue="Guid" Class="w-100" Data=@_productKindsForFilter TextProperty="Name" ValueProperty="Id"
                                    Change="(async ()=> await Reload())" />
                    </th>
                    <th class="action-block-col" scope="col">
                        <RadzenCheckBox @bind-Value=@_showHidden Name="CheckBox1" Change=@(async (bool args) => {_showHidden = args; await Reload(); }) />
                        <RadzenLabel Text="@Localizer["Show hidden"]" Component="CheckBox1" Style="margin-left: 8px; vertical-align: middle;" />
                    </th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><RadzenTextBox @bind-Value=@_newItem.Type Class="w-100" /></td>
                    <td><RadzenTextBox @bind-Value=@_newItem.Name Class="w-100" /></td>
                    <td>
                        <RadzenDropDown @bind-Value=@_newItem.ProductKindId TValue="Guid" Class="w-100" Data=@_productKinds TextProperty="Name" ValueProperty="Id" />
                    </td>
                    <td>
                        @if (_editedItem == null)
                        {
                            <div class="action-block">
                                <button class="btn btn-primary" type="button" @onclick="@(async () => await Add())">@Localizer["Add"]</button>
                            </div>
                        }
                    </td>
                </tr>
                @foreach (var item in _list)
                {
                    <tr>
                        @if (_editedItem?.Id == item.Id)
                        {
                            <td><RadzenTextBox @bind-Value=@_editedItem.Type Class="w-100" /></td>
                            <td><RadzenTextBox @bind-Value=@_editedItem.Name Class="w-100" /></td>
                            <td>
                                <RadzenDropDown @bind-Value=@_editedItem.ProductKindId TValue="Guid" 
                                Class="w-100" Data=@_productKinds TextProperty="Name" ValueProperty="Id" />
                            </td>
                        }
                        else
                        {
                            <td>@item.Type</td>
                            <td>@item.Name</td>
                            <td>@item.ProductKindName</td>
                        }

                        @if (_editedItem != null)
                        {
                            @if (_editedItem.Id == item.Id)
                            {
                                <td>
                                    <div class="action-block">
                                        <button class="btn btn-primary" type="button" @onclick="@(async () => await Save())">@Localizer["Save"]</button>
                                        <button class="btn btn-primary ms-2" type="button" @onclick="@(async () => Cancel())">@Localizer["Cancel"]</button>
                                    </div>
                                </td>
                            }
                            else
                            {
                                <td></td>
                            }
                        }
                        else
                        {
                            <td>
                                <div class="action-block">
                                    <button class="btn btn-primary" type="button" @onclick="@(async () => StartEdit(item))">@Localizer["Edit"]</button>
                                    <button class="btn btn-primary" type="button" @onclick="@(async () => await StartMergeProduct(item))">@Localizer["Merge"]</button>
                                    @if (!item.Used)
                                    {
                                        <button class="btn btn-primary" type="button" @onclick="@(async () =>await Delete(item))">@Localizer["Delete"]</button>
                                    }
                                    @if (!item.Hidden)
                                    {
                                        <button class="btn btn-primary" type="button" @onclick="@(async () =>await MarkAsHidden(item))">@Localizer["Mark as hidden"]</button>
                                    }else
                                    {
                                        <button class="btn btn-primary" type="button" @onclick="@(async () =>await MarkAsVisible(item))">@Localizer["Mark as visible"]</button>
                                    }
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
</div>