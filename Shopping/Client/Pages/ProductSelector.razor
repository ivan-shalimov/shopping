<RadzenRow Gap="1">
    <RadzenColumn Size="3" class="">
        <RadzenCard Style="height:600px; max-height:600px">
            <RadzenStack Orientation="Orientation.Vertical">
                @foreach (var (k, v) in _groups)
                {
                    <RadzenButton Variant="@(_selectedGroup == k ? Variant.Flat : Variant.Text)"
                              Click="@(()=>SelectGroup(k))"
                              Shade="Shade.Light"
                              Text="@v"
                              ButtonStyle="ButtonStyle.Info"
                              Size="ButtonSize.Small" />
                }
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
    <RadzenColumn Size="9" class="rz-background-color-base-50 rz-pl-2">
        <RadzenCard Style="height:600px; max-height:600px; overflow-y:auto">
            <RadzenRow Orientation="Orientation.Vertical">
                @foreach (var (k, v) in _products)
                {
                    <RadzenButton Style="width:150px; height:47px;margin-left:4px;"
                              Text="@v"
                              Click="@(()=>ChangeProductSelection(k))"
                              Variant="Variant.Flat"
                              Shade="@(_selectedProductIds.Contains(k) ? Shade.Default : Shade.Lighter)"
                              ButtonStyle="ButtonStyle.Primary"
                              Size="ButtonSize.Small" />
                }
            </RadzenRow>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
<RadzenRow class="rz-mt-2" JustifyContent="JustifyContent.End">
    <RadzenButton Variant="Variant.Outlined" Click=@(args => AddSelectedAndClose()) Text="@Localizer["AddSelectedAndClose"]" ButtonStyle="ButtonStyle.Success" />
    <RadzenButton Variant="Variant.Outlined" Click=@(args => Close()) Text="@Localizer["Close"]" ButtonStyle="ButtonStyle.Secondary" />
</RadzenRow>