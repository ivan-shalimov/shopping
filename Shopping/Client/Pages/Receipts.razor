@page "/receipts"

@inject IStringLocalizer<Resource> localizer

@using System.Net.Http.Json
@using Radzen
@using Radzen.Blazor
@using Shopping.Shared.Models.Results
@using Shopping.Shared.Requests


@inject HttpClient HttpClient

<ul class="nav nav-pills">
    @for (var i = 2023; i <= DateTime.Now.Year; i++)
    {
        <li class="nav-item">
            <a class="nav-link @(year == i ? "active" : "")" aria-current="page" href="/receipts?year=@i&month=@month">@i</a>
        </li>
    }
</ul>

<ul class="nav nav-pills">
    @for (var i = 1; i <= 12; i++)
    {
        <li class="nav-item">
                <a class="nav-link @(month == i ? "active" : "")" aria-current="page" href="/receipts?year=@year&month=@i">@i</a>
        </li>
    }
</ul>


<div class="row">
    @if (_pending)
    {
        <p>Loading ...</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">@localizer["Description"]</th>
                    <th scope="col">@localizer["Total"]</th>
                    <th scope="col">@localizer["Date"]</th>
                    <th class="action-block-col" scope="col"></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><RadzenTextBox @bind-Value=@_newItem.Description Class="w-100" /></td>
                    <td></td>
                    <td><RadzenDatePicker @bind-Value=@_newItem.Date DateFormat="d" Class="w-100"/></td>
                    <td>
                        @if (_editedItem == null)
                        {
                            <div class="action-block">
                                <button class="btn btn-primary" type="button" @onclick="@(async () => await Add())">@localizer["Add"]</button>
                            </div>
                        }
                    </td>
                </tr>
                @foreach (var item in _list)
                {
                    <tr>
                        @if (_editedItem?.Id == item.Id)
                        {
                            <td><RadzenTextBox @bind-Value=@_editedItem.Description Class="w-100" /></td>
                        }
                        else if (@item.Description.Length > 10)
                        {
                            <td> <a class="link" role="button" href="receipts/@item.Id">@item.Description</a></td>
                        }
                        else
                        {
                            <td> <a class="link" role="button" href="receipts/@item.Id">@item.Description (link)</a></td>
                        }

                        <td>@item.Total</td>

                        @if (_editedItem?.Id == item.Id)
                        {
                            <td><RadzenDatePicker @bind-Value=@_editedItem.Date DateFormat="d" Class="w-100"/></td>
                        }
                        else
                        {
                            <td>@item.Date</td>
                        }


                        @if (_editedItem != null)
                        {
                            @if (_editedItem.Id == item.Id)
                            {
                                <td>
                                    <div class="action-block">
                                        <button class="btn btn-primary" type="button" @onclick="@(async () => await Save())">@localizer["Save"]</button>
                                        <button class="btn btn-primary ms-2" type="button" @onclick="@(async () => Cancel())">@localizer["Cancel"]</button>
                                    </div>
                                </td>
                            }
                            else
                            {
                                <td></td>
                            }
                        }
                        else
                        {
                            <td>
                                <div class="action-block">
                                    <button class="btn btn-primary" type="button" @onclick="@(() => StartEdit(item))">@localizer["Edit"]</button>

                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public int? month { get; set; } = DateTime.UtcNow.Month;
    [Parameter]
    [SupplyParameterFromQuery]
    public int? year { get; set; } = DateTime.UtcNow.Year;

    private bool _pending = true;
    private int _listYear;
    private int _listMonth;
    private ReceiptModel[]? _list;

    private ReceiptModel _newItem = new ReceiptModel();
    private ReceiptModel _editedItem = null;

    protected override async Task OnParametersSetAsync()
    {
        month = month ?? DateTime.UtcNow.Month;
        year = year ?? DateTime.UtcNow.Year;

        if (month != _listMonth || year != _listYear)
        {
            _listMonth = month.Value;
            _listYear = year.Value;
        }
        else
        {
            return;
        }
        await Reload().ConfigureAwait(false);
        await base.OnParametersSetAsync();
    }

    private async Task Reload()
    {
        _pending = true;
        _list = await HttpClient.GetFromJsonAsync<ReceiptModel[]>($"/api/receipts?year={_listYear}&month={_listMonth}");
        _pending = false;
        if (_list == null)
        {
            return;
        }
    }

    private async Task Add()
    {
        var request = new AddReceipt
            {
                Id = Guid.NewGuid(),
                Description = _newItem.Description,
                Date = _newItem.Date,
            };

        await HttpClient.PostAsJsonAsync("/api/receipts", request);

        _newItem = new ReceiptModel();

        await Reload().ConfigureAwait(false);
    }

    private void StartEdit(ReceiptModel product)
    {
        _editedItem = product;
    }

    private void Cancel()
    {
        _editedItem = null;
    }

    private async Task Save()
    {
        await HttpClient.PutAsJsonAsync($"/api/receipts/{_editedItem.Id}", new UpdateReceipt { 
            Description = _editedItem.Description,
            Date = _editedItem.Date,
        });
        _editedItem = null;
        await Reload().ConfigureAwait(false);
    }

}