@inherits LayoutComponentBase
@inject IStringLocalizer<Resource> localizer

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @localizer["Welcome in"] @System.Globalization.CultureInfo.CurrentCulture.DisplayName
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
<RadzenComponents />