@page "/"

@using System.Net.Http.Json
@using Radzen.Blazor
@using Shopping.Models.Results


@inject HttpClient HttpClient
@inject NavigationManager NavigationManager
@inject AppSettigns Settigns

@if (_statistic == null)
{
    <p>Loading ...</p>
}
else
{
    <div class="row my-5">
        <div class="col-lg-6 col-xl-4 offset-lg-3 offset-xl-4">
            @foreach (var item in _statistic.Statistics)
            {
                <RadzenCard class="m-3">
                    <h3 class="h5">@item.Key</h3>
                    <div class="row">
                        <div class="col-md-4">
                        <b>@item.Value</b>
                    </div>
                    </div>
                </RadzenCard>
            }
        </div>
    </div>
}

@code{
    private PurchaseStatistic? _statistic;

    protected async override Task OnInitializedAsync()
    {
        _statistic = await HttpClient.GetFromJsonAsync<PurchaseStatistic>(Settigns.ApiUrl + "/purchases/statistic");
    }
}