@page "/list"

@using System.Net.Http.Json
@using Radzen
@using Radzen.Blazor
@using Shopping.Models.Results


@inject HttpClient HttpClient
@inject AppSettigns Settigns

<div class="row">
    @if (_list == null)
    {
        <p>Loading ...</p>
    }
    else
    {
        <div class="col-6">

            <table class="table ">
            <thead>
                <tr>
                    <th scope="col">Item</th>
                    <th scope="col">Price</th>
                    <th scope="col">Amount</th>
                    <th scope="col">Cost</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><RadzenAutoComplete Data=@_matchedItems TextProperty="Name" @bind-Value=@_newItem.Name LoadData=@OnLoadData Style="width: 100%;" /></td>
                    <td><RadzenNumeric ShowUpDown="false" TValue="decimal" @bind-Value=@_newItem.Price  Class="w-100" /></td>
                    <td><RadzenNumeric ShowUpDown="false" TValue="decimal" @bind-Value=@_newItem.Amount Class="w-100" /></td>
                    <td>@_newItem.Cost</td>
                    <td><button class="btn btn-primary" type="button" @onclick="@(async () => await Add())">Add</button></td>
                </tr>
                @foreach (var item in _list)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price</td>
                        <td>@item.Amount</td>
                        <td>@item.Cost</td>
                        <td><button class="btn btn-primary" type="button" @onclick="@(async () => await Delete(item.Id))">Delete</button></td>
                    </tr>
                }
            </tbody>
            </table>

        </div>
    }
</div>

@code{
    private PurchaseItem _newItem = new PurchaseItem();
    private PurchaseItem[]? _list;
    private IEnumerable<PurchaseItem> _matchedItems = Array.Empty<PurchaseItem>();

    protected override Task OnInitializedAsync()
    {
        return Reload();
    }

    void OnLoadData(LoadDataArgs args)
    {
        Console.WriteLine($"LoadData with filter: {args.Filter}");

        _matchedItems = _list.Where(c => c.Name.ToLower().StartsWith(args.Filter.ToLower())).DistinctBy(x=>x.Name).ToList();

        InvokeAsync(StateHasChanged);
    }

    private async Task Reload()
    {
        _list = null;
        _list = await HttpClient.GetFromJsonAsync<PurchaseItem[]>(Settigns.ApiUrl + "/purchases");
        if (_list == null)
        {
            return;
        }
    }

    private async Task Add()
    {
        var request = new Shopping.Requests.AddPurchase
        {
            Name = _newItem.Name,
            Price = _newItem.Price,
            Amount = _newItem.Amount,
        };

        await HttpClient.PostAsJsonAsync(Settigns.ApiUrl + "/purchases", request);

        _newItem = new PurchaseItem();

        await Reload().ConfigureAwait(false);
    }

    private async Task Delete(Guid id)
    {
        await HttpClient.DeleteAsync(Settigns.ApiUrl + $"/purchases/{id}");
        await Reload().ConfigureAwait(false);
    }


}