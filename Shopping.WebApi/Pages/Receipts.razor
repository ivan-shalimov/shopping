@page "/receipts"

@using System.Net.Http.Json
@using Radzen
@using Radzen.Blazor
@using Shopping.Models.Results
@using Shopping.Requests


@inject HttpClient HttpClient
@inject AppSettigns Settigns

<div class="row">
    @if (_pending)
    {
        <p>Loading ...</p>
    }
    else
    {
            <table class="table">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Date</th>
                    <th class="action-block-col" scope="col"></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><RadzenTextBox @bind-Value=@_newItem.Description Class="w-100" /></td>
                    <td></td>
                    <td>
                        <div class="action-block">
                            <button class="btn btn-primary" type="button" @onclick="@(async () => await Add())">Add</button>
                        </div>
                    </td>
                </tr>
                @foreach (var item in _list)
                {
                    <tr>
                        @if (_editedItem?.Id == item.Id)
                        {
                            <td><RadzenTextBox @bind-Value=@_editedItem.Description Class="w-100" /></td>
                        }
                        else
                        {
                            <td>@item.Description</td>
                        }
                        
                        <td>@item.CreatedOn</td>
                        
                        @if (_editedItem != null)
                        {
                            @if (_editedItem.Id == item.Id)
                            {
                                <td>
                                    <div class="action-block">
                                        <button class="btn btn-primary" type="button" @onclick="@(async () => await Save())">Save</button>
                                        <button class="btn btn-primary ms-2" type="button" @onclick="@(async () => Cancel())">Cancel</button>
                                    </div>
                                </td>
                            }
                            else
                            {
                                <td></td>
                            }
                        }
                        else
                        {
                            <td>
                                <div class="action-block">
                                    <button class="btn btn-primary" type="button" @onclick="@(() => StartEdit(item))">Edit</button>
                                    <a class="btn btn-secondary ms-2" role="button" href="receipts/@item.Id">Link</a>
                                </div>
                            </td>
                        }    
                    </tr>
                }
            </tbody>
            </table>
    }
</div>

@code{
    private bool _pending = true;
    private ReceiptModel[]? _list;

    private ReceiptModel _newItem = new ReceiptModel();
    private ReceiptModel _editedItem = null;

    protected override Task OnInitializedAsync()
    {
        return Reload();
    }

    private async Task Reload()
    {
        _pending = true;
        _list = await HttpClient.GetFromJsonAsync<ReceiptModel[]>(Settigns.ApiUrl + "/receipts");
        _pending = false;
        if (_list == null)
        {
            return;
        }
    }

    private async Task Add()
    {
        var request = new AddReceipt
        {
            Id = Guid.NewGuid(),
            Description = _newItem.Description,
        };

        await HttpClient.PostAsJsonAsync(Settigns.ApiUrl + "/receipts", request);

        _newItem = new ReceiptModel();

        await Reload().ConfigureAwait(false);
    }

    private void StartEdit(ReceiptModel product)
    {
        _editedItem = product;
    }

    private void Cancel()
    {
        _editedItem = null;
    }

    private async Task Save()
    {
        await HttpClient.PutAsJsonAsync(Settigns.ApiUrl + $"/receipts/{_editedItem.Id}", new UpdateReceipt{ Description = _editedItem.Description });
        _editedItem = null;
        await Reload().ConfigureAwait(false);
    }

}