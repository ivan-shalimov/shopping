        },
        "productKindTests": {
            "executor": "shared-iterations",
            "vus": 2,
            "iterations": 4,
            "maxDuration": "90s",
            "exec": "productKindTests"
        },
        "productTests": {
            "executor": "shared-iterations",
            "vus": 2,
            "iterations": 4,
            "maxDuration": "90s",
            "exec": "productTests"
        },
        "receiptTests": {
            "executor": "shared-iterations",
            "vus": 2,
            "iterations": 4,
            "maxDuration": "180s",
            "exec": "receiptTests"
        }
    },
    "userAgent": "MyK6UserAgentString/1.0"
